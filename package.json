    "test:all": "bun test && playwright test",
    "lighthouse": "bun build && lhci autorun",
    "lighthouse:ci": "lhci autorun --upload.target=temporary-public-storage",
    "perf:audit": "bun build && lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "bundle:size": "size-limit",
    "phylopic:curate": "bun scripts/fetch-phylopic-curated.ts",
