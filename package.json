{
  "name": "vetmed-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": "https://github.com/kjanat/vet-met-tracker",
  "author": "Kaj Kowalski <vetmed@kjanat.com>",
  "scripts": {
    "build": "next build --turbopack",
    "bundle:size": "size-limit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "bun scripts/migrate.ts",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "db:rollback": "drizzle-kit rollback",
    "db:seed": "bun scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "deploy:production": "bun run build && vercel deploy --prebuilt --prod",
    "deploy:staging": "bun run build && vercel deploy --prebuilt",
    "deploy:validate": "bun run prod:validate",
    "dev": "next dev --turbopack",
    "format": "biome format --fix",
    "format:md": "markdownlint-cli2 \"**/*.{md,markdown}\" \"#node_modules\" --fix",
    "lighthouse": "bun run build && lhci autorun",
    "lighthouse:ci": "lhci autorun --upload.target=temporary-public-storage",
    "lint": "bun run format && biome lint",
    "lint:fix": "bun run format && biome check --fix",
    "monitoring:health": "curl http://localhost:3000/api/health",
    "perf:audit": "bun run build && lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "phylopic:curate": "bun run scripts/fetch-phylopic-curated.ts",
    "prepare": "husky",
    "preview": "next build && next start",
    "preview:dev": "vercel dev",
    "prod:validate": "bun test && bun lighthouse:ci",
    "start": "next start",
    "test": "bun test",
    "test:agent": "cross-env AGENT=1 bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "next typegen && tsgo --noEmit --strict && echo \"Success: No type errors detected\"",
    "typegen": "next typegen",
    "validate": "bun run typegen && bun run typecheck && biome lint && cross-env AGENT=1 bun test --coverage && bun run build"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "bufferutil",
    "esbuild",
    "msw",
    "puppeteer",
    "sharp",
    "unrs-resolver"
  ],
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@neondatabase/serverless": "^1.0.2",
    "@next/env": "^15.5.4",
    "@next/mdx": "^15.5.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@stackframe/stack": "^2.8.41",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.6.0",
    "@trpc/next": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "@types/mdx": "^2.0.13",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^11.0.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "bufferutil": "^4.0.9",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "8.6.0",
    "eslint-config-next": "^15.5.4",
    "geist": "^1.5.1",
    "input-otp": "1.4.2",
    "ioredis": "^5.8.0",
    "isomorphic-dompurify": "^2.27.0",
    "lucide-react": "^0.544.0",
    "luxon": "^3.7.2",
    "next": "^15.5.4",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-day-picker": "^9.11.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.63.0",
    "react-hooks": "^1.0.1",
    "react-resizable-panels": "^3.0.6",
    "recharts": "2.15.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "web-vitals": "^5.1.0",
    "ws": "^8.18.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@happy-dom/global-registrator": "^19.0.2",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^15.5.4",
    "@playwright/test": "^1.55.1",
    "@react-buddy/ide-toolbox": "^2.4.0",
    "@size-limit/preset-app": "^11.2.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.23",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/jsdom": "^27.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/sinon": "^17.0.4",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20250930.1",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "bun-osv-scanner": "^1.0.0",
    "commander": "^14.0.1",
    "cross-env": "^10.1.0",
    "crossenv": "^0.0.2-security",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.5",
    "esbuild": "^0.25.9",
    "eslint": "^9",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.0",
    "lighthouse": "^12.8.2",
    "lint-staged": "^16.2.3",
    "markdownlint-cli2": "^0.18.1",
    "postcss": "^8.5.6",
    "postgres": "^3.4.7",
    "puppeteer": "^24.22.3",
    "shadcn": "^3.3.1",
    "sinon": "^21.0.0",
    "size-limit": "^11.2.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vercel": "^48.1.6"
  },
  "overrides": {
    "react-is": "^19.0.0-rc-69d4b800-20241021"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "packageManager": "bun@1.2.23",
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "bunx biome check --staged --write --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error"
    ],
    "*.{md,markdown}": [
      "bunx markdownlint-cli2 --fix"
    ],
    "*.sh": [
      "shfmt -w",
      "shellcheck"
    ]
  }
}
